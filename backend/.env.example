GEMINI_API_KEY=
ES_HOST=http://localhost:9200
ES_INDEX=rag_chunks
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# Embedding Provider Configuration (gemini or ollama)
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMS=768
OLLAMA_HOST=http://localhost:11434

# LayoutParser & Table Transformer (TATR) Ingestion Config
LAYOUT_MODEL=lp://PubLayNet/ppyolov2_r50vd_dcn_365e
LAYOUT_CONFIDENCE_THRESHOLD=0.5
RENDER_DPI=200
TABLE_MODEL=microsoft/table-transformer-structure-recognition-v1.1-all
TABLE_DEVICE=cpu
FIGURE_CAPTION_MAX_CHARS=400

# PostgreSQL Database & JWT Auth Config
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/capitalquery
JWT_SECRET=super_secret_jwt_key_change_me_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

